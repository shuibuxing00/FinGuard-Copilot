# =============================================================================
# FinGuard Compliance Copilot — Example Environment Configuration
# Copy to .env and adjust values. Never commit .env to version control.
# =============================================================================

# --- OpenAI (LLM backend for splunklib.ai.Agent) ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# --- Splunk Enterprise (Management API port 8089, NOT web UI port 8000) ---
SPLUNK_HOST=localhost
SPLUNK_PORT=8089
SPLUNK_WEB_PORT=8000
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=your_splunk_password
SPLUNK_INDEX=main
SPLUNK_SCHEME=https
SPLUNK_VERIFY_SSL=false
SPLUNK_SEARCH_TIMEOUT=60
SPLUNK_USE_REAL=true

# --- Application ---
DEBUG=False
LOG_LEVEL=INFO
# AUDIT_LOG_FILE=.audit_chain.json
# COMPLIANCE_LAWS_DIR=data/compliance_laws
